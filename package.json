{
	"name": "git-history-import",
	"version": "0.1.0",
	"description": "Export git history to JSON, edit it, import it back",
	"type": "module",
	"bin": {
		"ghi": "./bin/ghi.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"bin"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"git",
		"history",
		"export",
		"import",
		"json"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tomchen/git-history-import.git"
	},
	"homepage": "https://github.com/tomchen/git-history-import#readme",
	"bugs": {
		"url": "https://github.com/tomchen/git-history-import/issues"
	},
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.2",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
