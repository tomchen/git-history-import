{
	"name": "git-history-import",
	"version": "0.1.0",
	"description": "Export git history to JSON, edit it, import it back",
	"type": "module",
	"bin": {
		"ghi": "./bin/ghi.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"bin"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
		"check": "npm run lint:check && npm run format:check && npm run typecheck",
		"clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint --write .",
		"lint:check": "biome lint .",
		"prepublishOnly": "npm run clean && npm run build",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"git",
		"history",
		"export",
		"import",
		"json"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tomchen/git-history-import.git"
	},
	"homepage": "https://github.com/tomchen/git-history-import#readme",
	"bugs": {
		"url": "https://github.com/tomchen/git-history-import/issues"
	},
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.2",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
